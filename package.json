{
  "name": "webscrollmap",
  "version": "0.1.0",
  "private": true,
  "description": "Safari Web Extension — 긴 웹페이지를 지도처럼 탐색",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "ENTRY=content vite build && ENTRY=background vite build && ENTRY=popup vite build",
    "dev": "ENTRY=content vite build --watch --mode development",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf": "playwright test --project=webkit tests/perf"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@playwright/test": "^1.45.0",
    "happy-dom": "^14.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
